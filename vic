.btn-primary{background:#1B3A5C;color:#fff;}
.btn-outline{background:#fff;color:#1B3A5C;border:1.5px solid #1B3A5C;margin-right:8px;}
.proposal{background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.10);overflow:hidden;}
@media print{body{background:#fff;padding:0;}.toolbar{display:none;}.proposal{box-shadow:none;border-radius:0;}}
</style>
</head><body>
<div class="page-wrap">
  <div class="toolbar">
    <h1>Proposal Preview — ${clientName}</h1>
    <div>
      <button class="btn btn-outline" onclick="window.print()">🖨 Print / Save PDF</button>
      <button class="btn btn-primary" onclick="window.close()">✕ Close</button>
    </div>
  </div>
  <div class="proposal">
    <div style="background:#1B3A5C;padding:36px 44px;display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <div style="font-family:'Instrument Serif',serif;font-size:1.6rem;color:#fff;letter-spacing:.3px;">Westcor Energy</div>
        <div style="font-size:.65rem;color:rgba(255,255,255,.55);letter-spacing:2.5px;text-transform:uppercase;margin-top:3px;">Commercial Energy Services</div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.5);margin-bottom:4px;">New Contract Proposal</div>
        <div style="font-size:.85rem;color:rgba(255,255,255,.85);font-weight:500;">${today}</div>
      </div>
    </div>
    <div style="background:#f0f4f8;border-bottom:1px solid #e5e7eb;padding:18px 44px;display:flex;gap:40px;">
      <div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:1.2px;color:#9ca3af;font-weight:600;margin-bottom:3px;">Prepared For</div><div style="font-size:.95rem;font-weight:600;color:#1a1f2e;">${clientName}</div></div>
      <div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:1.2px;color:#9ca3af;font-weight:600;margin-bottom:3px;">Service Address</div><div style="font-size:.95rem;font-weight:600;color:#1a1f2e;">${clientAddr}</div></div>
      <div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:1.2px;color:#9ca3af;font-weight:600;margin-bottom:3px;">Utility</div><div style="font-size:.95rem;font-weight:600;color:#1a1f2e;">${clientUtil}</div></div>
      <div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:1.2px;color:#9ca3af;font-weight:600;margin-bottom:3px;">Annual Usage</div><div style="font-size:.95rem;font-weight:600;color:#1a1f2e;">${clientVol} kWh</div></div>
    </div>
    <div style="padding:36px 44px;">
      <div style="font-size:.88rem;color:#6b7280;line-height:1.7;margin-bottom:32px;border-left:3px solid #1B3A5C;padding-left:16px;">
        We have secured competitive fixed-rate offers on your behalf from multiple licensed retail energy providers. Rates below are all-inclusive and fixed for the full contract term — no hidden fees, no surprises.
      </div>
      ${suppliersHTML}
      <div style="background:#f9fafb;border-radius:8px;padding:16px 20px;font-size:.8rem;color:#6b7280;line-height:1.7;margin-top:28px;">
        <strong style="color:#374151;">Important:</strong> Rates are valid for <strong style="color:#374151;">24 hours</strong> from the date of this proposal. All rates are fixed all-inclusive and do not include applicable taxes. Contract start date is subject to utility enrollment timelines. To lock in your rate, sign and return this proposal.<br><br>
        <strong style="color:#374151;">Next Steps:</strong> Once this proposal is signed, we will send over your official contract for final execution. Our team will guide you through the enrollment process from start to finish.
      </div>
    </div>
    <div style="background:#1B3A5C;padding:24px 44px;display:flex;justify-content:space-between;align-items:center;">
      <div style="font-family:'Instrument Serif',serif;font-size:1rem;color:#fff;">Westcor Energy</div>
      <div style="display:flex;gap:24px;">
        <div style="font-size:.8rem;color:rgba(255,255,255,.75);">📞 <strong style="color:#fff;">${BROKER_INFO.phone}</strong></div>
        <div style="font-size:.8rem;color:rgba(255,255,255,.75);">✉ <strong style="color:#fff;">${BROKER_INFO.email}</strong></div>
        <div style="font-size:.8rem;color:rgba(255,255,255,.75);">🌐 <strong style="color:#fff;">${BROKER_INFO.website}</strong></div>
      </div>
    </div>
  </div>
</div>
</body></html>`);
  w.document.close();
  closeModal('proposal-overlay');

  if(mode==='pandadoc'){
    // Ask for client email then send via PandaDoc
    const clientEmail=prompt(`Enter ${clientName}'s email address to send via PandaDoc:`);
    if(clientEmail&&clientEmail.includes('@')){
      sendViaPandaDoc(clientName, clientEmail, `Proposal for ${clientName} — ${today}`);
    } else if(clientEmail){
      showToast('Invalid email address.');
    }
  }
}
let toastTimer;
function showToast(msg){
  const t=document.getElementById('toast-el');
  t.textContent=msg;t.classList.add('show');
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2800);
}
</script>
</body>
</html>
