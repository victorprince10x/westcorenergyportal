async function sendViaPandaDoc(clientName, clientEmail, proposalHTML) {
  if (!PANDADOC_API_KEY) {
    showToast('Add your PandaDoc API key in ⚙️ Settings first.');
    return;
  }
  showToast('Sending to PandaDoc...');
  try {
