async function handleBillUpload(input) {
  const file=input.files[0];if(!file)return;
  if(!ANTHROPIC_API_KEY){showToast('Add your API key in Settings first.');input.value='';return;}
  const overlay=document.getElementById('bill-parsing-overlay');
  const statusEl=document.getElementById('bill-status');
  const spinner=document.getElementById('bill-spinner');
  overlay.style.display='flex';
  const spinFrames=['⚡','🔆','💡','🔆'];let si=0;
  const spinInterval=setInterval(()=>{spinner.textContent=spinFrames[si++%spinFrames.length];},400);
  try {
    const base64=await new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.onerror=rej;r.readAsDataURL(file);});
    const isPDF=file.type==='application/pdf';
    statusEl.textContent='Analyzing bill with AI...';
    const response=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':ANTHROPIC_API_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:[{type:isPDF?'document':'image',source:{type:'base64',media_type:file.type,data:base64}},{type:'text',text:'Extract zip, commodity, state, annual_volume, utility, load_profile from this bill. Return ONLY valid JSON, no markdown.'}]}]})});
    const data=await response.json();
    const text=data.content?.find(b=>b.type==='text')?.text||'{}';
    const parsed=JSON.parse(text.replace(/```json|```/g,'').trim());
    if(parsed.zip)document.getElementById('p-zip').value=parsed.zip;
    if(parsed.commodity)document.getElementById('p-commodity').value=parsed.commodity;
    if(parsed.state)setSelectByText('p-state',parsed.state);
    if(parsed.annual_volume)document.getElementById('p-volume').value=Math.round(parsed.annual_volume);
    if(parsed.utility)setSelectByText('p-utility',parsed.utility);
    clearInterval(spinInterval);overlay.style.display='none';input.value='';
    showToast('✓ Bill parsed — form auto-populated!');
  } catch(err){clearInterval(spinInterval);overlay.style.display='none';input.value='';showToast('Could not read bill. Please fill in manually.');}
}

function setSelectByText(id,text){
  if(!text)return;const sel=document.getElementById(id);if(!sel)return;
  const lower=text.toLowerCase();
  for(const opt of sel.options){if(opt.textContent.toLowerCase().includes(lower)||lower.includes(opt.textContent.toLowerCase())){sel.value=opt.value;return;}}
}

