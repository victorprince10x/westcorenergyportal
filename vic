    const response = await fetch('https://api.pandadoc.com/public/v1/documents', {
      method: 'POST',
      headers: {
        'Authorization': `API-Key ${PANDADOC_API_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        name: `Energy Proposal — ${clientName}`,
        recipients: [{ email: clientEmail, first_name: clientName, role: 'Client' }],
        content: [{ type: 'text', data: proposalHTML }],
        tags: ['westcor-energy', 'proposal']
