    const initials=clientName.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
    const badge=statusMap[p.status]||'b-neutral';
    const sentDate=p.sent_at?new Date(p.sent_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—';
    const proNum=`#PRO-${new Date(p.sent_at||Date.now()).getFullYear()}-${String(i+1).padStart(4,'0')}`;
    return`<tr>
      <td><span style="font-family:'DM Mono',monospace;font-size:11.5px;color:#1a5fd4">${proNum}</span></td>
      <td><div style="display:flex;align-items:center;gap:9px;"><div class="av">${initials}</div><div><div class="fw">${clientName}</div><div style="font-size:11.5px;color:#9ca3af;">${location}</div></div></div></td>
