<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="wc-right">
    <div class="wc-card">
      <div class="wc-brand">
        <div class="wc-brand-name">Westcor Energy</div>
        <div class="wc-brand-sub">Commercial Energy Services</div>
      </div>
      <div class="wc-form-title">Sign in</div>
      <div class="wc-form-sub">Access your Westcor broker portal</div>
      <div class="wc-field"><label>Email</label><input type="email" id="login-email"></div>
      <div class="wc-field"><label>Password</label><input type="password" id="login-pass"></div>
      <button class="wc-submit" onclick="doLogin()">Sign In</button>
      <div class="wc-error" id="login-err">Incorrect email or password.</div>
      <div class="wc-links-row">
        <a href="#" class="wc-link-muted">Forgot Password?</a>
        <a href="#" class="wc-link-accent" onclick="openModal('signup-overlay');return false;">Request Access</a>
      </div>
    </div>
  </div>
</div>

<!-- SIGNUP MODAL -->
<div class="overlay" id="signup-overlay">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2>Request Access</h2>
      <button class="modal-close" onclick="closeModal('signup-overlay')">×</button>
    </div>
    <div class="modal-body">
      <div style="font-size:13px;color:#6b7280;margin-bottom:18px;line-height:1.6;">Fill in your info below. Once approved, you'll receive login credentials from Westcor Energy.</div>
      <div class="wc-field"><label style="font-size:.7rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#5C5A54;">Full Name</label><input class="inp" type="text" id="signup-name" placeholder="Jane Smith"></div>
      <div class="wc-field"><label style="font-size:.7rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#5C5A54;">Email</label><input class="inp" type="email" id="signup-email" placeholder="jane@company.com"></div>
      <div class="wc-field"><label style="font-size:.7rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#5C5A54;">Phone</label><input class="inp" type="tel" id="signup-phone" placeholder="(832) 555-0000"></div>
      <div class="wc-field"><label style="font-size:.7rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#5C5A54;">Message (optional)</label><textarea class="inp" id="signup-message" placeholder="Tell us about yourself..." style="height:80px;resize:none;"></textarea></div>
      <div id="signup-status" style="display:none;font-size:12px;padding:8px 12px;border-radius:5px;margin-top:4px;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('signup-overlay')">Cancel</button>
      <button class="btn btn-primary" onclick="submitAccessRequest()">Submit Request</button>
    </div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <nav class="topnav">
    <div class="nav-brand">Westcor Energy</div>
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="showPage('pricing',this)">Pricing</button>
      <button class="nav-tab" onclick="showPage('proposals',this)">Proposals</button>
      <button class="nav-tab" onclick="showPage('accounts',this)">Accounts</button>
      <button class="nav-tab" onclick="showPage('reports',this)">Reports</button>
    </div>
