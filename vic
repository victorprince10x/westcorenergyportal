      <td>${p.term||'—'} mo</td>
      <td><span class="rate r-default">$${p.rate||'—'}</span></td>
      <td>${p.volume?Number(p.volume).toLocaleString():'—'} kWh</td>
      <td>${sentDate}</td>
      <td><span class="badge ${badge}">${p.status||'pending'}</span></td>
      <td>—</td>
      <td><button class="btn btn-ghost btn-sm" onclick="showToast('Proposal opened')">View</button></td>
    </tr>`;
  }).join('');
}

// ── RATES FROM SUPABASE ──
async function loadRatesFromDB(){
  if(!sb)return;
  const{data,error}=await sb.from('rates').select('*').order('uploaded_at',{ascending:false});
  if(error||!data||!data.length)return;
  const grouped={};
  data.forEach(r=>{
    if(!grouped[r.supplier])grouped[r.supplier]={name:r.supplier,cls:'l-nrg',rates:[null,null,null,null,null,null]};
    const tMap={12:0,18:1,24:2,36:3,48:4,60:5};
    [12,18,24,36,48,60].forEach(t=>{if(r[`rate_${t}`])grouped[r.supplier].rates[tMap[t]]=parseFloat(r[`rate_${t}`]);});
  });
  if(Object.keys(grouped).length){
    BASE_RATES.splice(0,BASE_RATES.length,...Object.values(grouped));
    recalcRates();
    showToast('Live rates loaded ✓');
  }
}

